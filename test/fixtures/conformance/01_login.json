{
  "name": "login: happy path, bad credentials, per-username lockout",
  "description": "POST /login issues a device token on success; wrong password is 403 bad_credentials; 5 consecutive failures for one username (from distinct IPs, so the per-IP limiter never trips) locks that username out with 429 locked_out, independent of the per-IP rate limiter.",
  "seed": {
    "users": [
      { "as": "dan", "name": "dan", "password": "correcthorsebatterystaple" },
      { "as": "flo", "name": "flo", "password": "another-fake-pw-99" }
    ]
  },
  "steps": [
    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.1.1.1" },
      "body": { "username": "dan", "password": "wrong-password", "device_name": "dans-mac" },
      "expect": { "status": 403, "body": { "error": "bad_credentials" } } },

    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.1.1.2" },
      "body": { "username": "dan", "password": "correcthorsebatterystaple", "device_name": "dans-mac" },
      "expect": { "status": 200, "body": {
        "token": { "$bind": "dan_token" },
        "device_id": { "$type": "integer" },
        "user_id": { "$ref": "dan.user_id" }
      } } },

    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.2.2.1" },
      "body": { "username": "flo", "password": "wrong-1", "device_name": "x" },
      "expect": { "status": 403, "body": { "error": "bad_credentials" } } },
    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.2.2.2" },
      "body": { "username": "flo", "password": "wrong-2", "device_name": "x" },
      "expect": { "status": 403, "body": { "error": "bad_credentials" } } },
    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.2.2.3" },
      "body": { "username": "flo", "password": "wrong-3", "device_name": "x" },
      "expect": { "status": 403, "body": { "error": "bad_credentials" } } },
    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.2.2.4" },
      "body": { "username": "flo", "password": "wrong-4", "device_name": "x" },
      "expect": { "status": 403, "body": { "error": "bad_credentials" } } },
    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.2.2.5" },
      "body": { "username": "flo", "password": "wrong-5", "device_name": "x" },
      "expect": { "status": 403, "body": { "error": "bad_credentials" } } },

    { "kind": "http", "method": "POST", "path": "/login",
      "headers": { "cf-connecting-ip": "10.2.2.6" },
      "body": { "username": "flo", "password": "another-fake-pw-99", "device_name": "x" },
      "expect": {
        "status": 429,
        "headers": { "retry-after": { "$type": "string" } },
        "body": { "error": "locked_out", "retry_after": { "$type": "integer" } }
      } }
  ]
}
