{
  "name": "POST /password: happy path, wrong old_password 401, agent devices forbidden",
  "description": "A wrong old_password is 401 bad_password; an agent device (never holds a user's password) is 403 forbidden outright; on success the hash rotates but the device token used to make the request stays valid (a password change doesn't revoke sessions).",
  "seed": {
    "users": [{ "as": "dan", "name": "dan", "password": "original-fixture-pw" }],
    "agents": [{ "as": "bridge", "user": "dan", "name": "dev-2" }]
  },
  "steps": [
    { "kind": "http", "method": "POST", "path": "/login",
      "body": { "username": "dan", "password": "original-fixture-pw", "device_name": "mac" },
      "expect": { "status": 200, "body": {
        "token": { "$bind": "dan_token" }, "device_id": { "$type": "integer" }, "user_id": { "$ref": "dan.user_id" }
      } } },

    { "kind": "http", "method": "POST", "path": "/password", "token": { "$ref": "dan_token" },
      "body": { "old_password": "the-wrong-password", "new_password": "brand-new-fixture-pw" },
      "expect": { "status": 401, "body": { "error": "bad_password" } } },

    { "kind": "http", "method": "POST", "path": "/password", "token": { "$ref": "bridge.token" },
      "body": { "old_password": "original-fixture-pw", "new_password": "brand-new-fixture-pw" },
      "expect": { "status": 403, "body": { "error": "forbidden" } } },

    { "kind": "http", "method": "POST", "path": "/password", "token": { "$ref": "dan_token" },
      "body": { "old_password": "original-fixture-pw", "new_password": "brand-new-fixture-pw" },
      "expect": { "status": 200, "body": { "ok": true } } },

    { "kind": "http", "method": "POST", "path": "/login",
      "body": { "username": "dan", "password": "original-fixture-pw", "device_name": "x" },
      "expect": { "status": 403, "body": { "error": "bad_credentials" } } },
    { "kind": "http", "method": "POST", "path": "/login",
      "body": { "username": "dan", "password": "brand-new-fixture-pw", "device_name": "x" },
      "expect": { "status": 200, "body": {
        "token": { "$type": "string" }, "device_id": { "$type": "integer" }, "user_id": { "$ref": "dan.user_id" }
      } } },

    { "kind": "http", "method": "GET", "path": "/snapshot", "token": { "$ref": "dan_token" },
      "expect": { "status": 200, "body": { "conversations": [], "seq": 0 } } }
  ]
}
